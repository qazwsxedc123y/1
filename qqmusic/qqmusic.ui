              <property name="styleSheet">
               <string notr="true">/* 类型选择器 - 应用到所有 QPushButton */
QPushButton
{
    border-radius: 0px;              /* 直角边缘 */
    background-repeat: no-repeat;    /* 图片不重复 */
    border: none;                    /* 无边框 */
    background-position: center center; /* 图片居中 */
}

/* 悬停状态 - 鼠标移上时 */
QPushButton:hover
{
    background-color: rgba(230, 0, 0, 0.5);  /* 半透明红色遮罩 */
}</string>
